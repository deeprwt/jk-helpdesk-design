# ──────────────────────────────────────────────────────────
# CGB Helpdesk — Environment Variables
# Copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:Deepak1234@localhost:5432/jk_helpdesk_db

# JWT secret — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server port
PORT=3000

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=deepak.rawat@cgbindia.com
SMTP_PASS=gaewdhouidcodqph
SMTP_FROM=deepak.rawat@cgbindia.com

# Cron secret for SLA check endpoint (set any random string)
CRON_SECRET=your-cron-secret-here
